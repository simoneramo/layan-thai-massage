# Resend — required for the contact/booking form to actually send email.
# Get a key at https://resend.com  (Settings → API Keys)
RESEND_API_KEY=

# Where booking requests are delivered (defaults to info@layanthaimassage.com.au)
BOOKING_TO_EMAIL=info@layanthaimassage.com.au

# Verified sender. Use a verified domain in production, e.g. "Layan <bookings@layanthaimassage.com.au>".
# Falls back to Resend's shared test sender if unset.
BOOKING_FROM_EMAIL=Layan Website <onboarding@resend.dev>

# Online booking (/book) — password for the /admin bookings dashboard.
ADMIN_PASSWORD=change-me

# Optional: set only if the public URL differs from the request origin (e.g.
# behind a proxy). Left blank, cancel links use the live request origin.
NEXT_PUBLIC_BASE_URL=
